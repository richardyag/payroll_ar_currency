<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Agrega "Moneda del salario" en el formulario de contratos,
         justo antes del campo Salario para que sea visualmente claro
         que ambos van juntos. -->
    <record id="hr_contract_view_form_wage_currency" model="ir.ui.view">
        <field name="name">hr.contract.form.wage.currency</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='wage']" position="before">
                <field name="wage_currency_id"
                       string="Moneda del salario"
                       options="{'no_create': True, 'no_open': True}"
                       widget="many2one"/>
            </xpath>

        </field>
    </record>

</odoo>
